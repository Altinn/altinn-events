meta {
  name: organization number identified subunit
  type: http
  seq: 4
}

post {
  url: {{PlatformHostUrl}}/events/api/v1/outbound
  body: json
  auth: inherit
}

headers {
  Content-Type: application/cloudevents+json
  PlatformAccessToken: {{AccessToken}}
}

body:json {
  {
    "id": "{{$randomUUID}}",
    "time": "{{$isoTimestamp}}",
    "type": "no.altinn.correspondence.correspondencereceiverneverread",
    "source": "https://platform.tt02.altinn.no/correspondence/api/v1/correspondence",
    "subject": "urn:altinn:organization:identifier-no:311443755",
    "resource": "urn:altinn:resource:nabovarsel",
    "specversion": "1.0",
    "resourceinstance": "019ce781-a5c0-7d03-8f51-3e7dda66dd74"
  }
}

script:pre-request {
  await bru.runRequest("Token generator/platform access token");
  
}

settings {
  encodeUrl: true
  timeout: 0
}
