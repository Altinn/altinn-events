meta {
  name: party id identified subunit
  type: http
  seq: 1
}

post {
  url: {{PlatformHostUrl}}/events/api/v1/outbound
  body: json
  auth: inherit
}

headers {
  Content-Type: application/cloudevents+json
  PlatformAccessToken: {{AccessToken}}
}

body:json {
  {
    "id": "{{$randomUUID}}",
    "time": "{{$isoTimestamp}}",
    "type": "app.instance.created",
    "source": "https://ttd.apps.at22.altinn.cloud/ttd/apps-test/instances/51326197/428a4575-2c04-4400-89a3-1aaadd2579cd",
    "resource": "urn:altinn:resource:app_ttd_apps-test",
    "resourceinstance": "51326197/428a4575-2c04-4400-89a3-1aaadd2579cd",
    "subject": "/party/51326197",
    "specversion": "1.0",
    "alternativesubject": "/organization/311443755"
  }
}

script:pre-request {
  await bru.runRequest("Token generator/platform access token");
  
}

settings {
  encodeUrl: true
  timeout: 0
}
