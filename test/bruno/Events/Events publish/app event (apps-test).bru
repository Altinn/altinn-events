meta {
  name: app event (apps-test)
  type: http
  seq: 1
}

post {
  url: {{PlatformHostUrl}}/events/api/v1/app
  body: json
  auth: inherit
}

headers {
  Content-Type: application/cloudevents+json
  PlatformAccessToken: {{AccessToken}}
}

body:json {
  {
    "specversion": "1.0",
    "time": "{{$isoTimestamp}}",
    "type": "app.instance.created",
    "source": "https://ttd.apps.at22.altinn.cloud/ttd/apps-test/instances/50019855/428a4575-2c04-4400-89a3-1aaadd2579cd",
    "subject": "/party/51282358",
    "alternativesubject": "/org/311085972"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
