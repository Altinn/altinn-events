meta {
  name: publish admin (dialogporten)
  type: http
  seq: 4
}

get {
  url: {{TokenGeneratorBaseUrl}}/api/GetEnterpriseToken?env={{Environment}}&scopes=altinn:events.publish altinn:events.publish.admin&orgNo=991825827&org=ttd
  body: none
  auth: basic
}

params:query {
  env: {{Environment}}
  scopes: altinn:events.publish altinn:events.publish.admin
  orgNo: 991825827
  org: ttd
}

auth:basic {
  username: {{TokenGeneratorUserName}}
  password: {{TokenGeneratorPassword}}
}

script:post-response {
  const token = res.getBody();
  bru.setVar("BearerToken", token);
}

settings {
  encodeUrl: true
  timeout: 0
}
